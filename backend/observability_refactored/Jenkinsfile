pipeline {
    agent any

    options {
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Files') {
            steps {
                dir('backend/observability_refactored') {
                    sh '''
                        pwd
                        ls -la
                    '''
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                dir('backend/observability_refactored') {
                    sh '''
                        docker compose build --no-cache
                    '''
                }
            }
        }

        stage('Stop Existing Containers') {
            steps {
                dir('backend/observability_refactored') {
                    sh '''
                        docker compose down || true
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('backend/observability_refactored') {
                    sh '''
                        docker compose up -d
                    '''
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    docker ps
                '''
            }
        }

        stage('Cleanup') {
            steps {
                sh '''
                    docker image prune -f
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful!'
        }

        failure {
            echo 'Deployment Failed!'
        }

        always {
            sh 'docker ps -a'
        }
    }
}
