# .env.example — copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=observability

# Constructed URL for API and Worker
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/sai

# Redis
REDIS_URL=redis://redis:6379/0

# API Settings
APP_ENV=development
API_ENV=SH_OBSERVABILITY
ADMIN_SECRET_KEY=change-this-to-a-strong-secret
ALLOWED_PROJECTS=["GCP"]
AUTH_CACHE_TTL_SECONDS=3600
CORS_ALLOWED_ORIGINS=*
LOG_LEVEL=INFO
QUEUE_BACKEND=redis

# Worker Settings
WORKER_COUNT=4
BATCH_SIZE=100
POLL_TIMEOUT=5

# Azure OpenAI (DeepEval)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_BASE_URL=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini-prod
